      "Bash(zellij action:*)",
      "Bash(echo:*)",
      "Bash(./target/debug/workmux:*)",
      "Bash(git worktree:*)",
      "Bash(workmux add:*)",
      "Bash(for tab in wm-test9 wm-test10 wm-test11)",
